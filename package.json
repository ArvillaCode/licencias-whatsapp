{
  "name": "apto-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && npm --prefix frontend install && npm --prefix frontend run build",
    "db:push": "prisma db push",
    "db:seed": "tsx backend/prisma/seed.ts",
    "backup": "tsx backend/scripts/backup.ts"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma",
    "seed": "tsx backend/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@vercel/blob": "^0.27.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.0",
    "prisma": "^5.20.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
