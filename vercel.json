{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/admin/auth/:path*", "destination": "/api/index.js" },
    { "source": "/admin/licenses", "destination": "/api/index.js" },
    { "source": "/admin/license/:path*", "destination": "/api/index.js" },
    { "source": "/api/:path*", "destination": "/api/index.js" }
  ],
  "env": {
    "NODE_VERSION": "18.x"
  }
}
