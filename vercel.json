{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/admin/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/admin/licenses", "dest": "/api/index.js" },
    { "src": "/admin/license/(.*)", "dest": "/api/index.js" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/public/admin/login.html" },
    { "src": "/admin", "dest": "/public/admin/login.html" },
    { "src": "/admin/", "dest": "/public/admin/login.html" },
    { "src": "/admin/(.*)", "dest": "/public/admin/$1" }
  ],
  "env": {
    "NODE_VERSION": "18.x"
  }
}
