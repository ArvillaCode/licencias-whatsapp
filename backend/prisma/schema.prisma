generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         String   @default("MEMBER") // "ADMIN" | "MEMBER"
  permissions  String[] @default([]) // "dashboard" | "units" | "bills" | "catalogs"
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Unit {
  id          Int      @id @default(autoincrement())
  address     String
  apartmentNo String
  name        String?
  tenantName  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bills       Bill[]
}

model BillType {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  order  Int     @default(0)
  active Boolean @default(true)
  bills  Bill[]
}

model Bill {
  id             Int             @id @default(autoincrement())
  unitId         Int
  unit           Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  billTypeId     Int
  billType       BillType        @relation(fields: [billTypeId], references: [id])
  billNumber     String?
  dueDate        DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  monthlyRecords MonthlyRecord[]

  @@unique([unitId, billTypeId])
}

model MonthlyRecord {
  id            Int        @id @default(autoincrement())
  billId        Int
  bill          Bill       @relation(fields: [billId], references: [id], onDelete: Cascade)
  month         Int
  year          Int
  responsible   String?
  amountPaid    Float?
  paymentMethod String?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  evidences     Evidence[]

  @@unique([billId, month, year])
}

model Evidence {
  id              Int           @id @default(autoincrement())
  monthlyRecordId Int
  monthlyRecord   MonthlyRecord @relation(fields: [monthlyRecordId], references: [id], onDelete: Cascade)
  fileName        String
  url             String        @default("")
  originalName    String
  mimeType        String
  sizeBytes       Int
  uploadedAt      DateTime      @default(now())
}

model PaymentMethod {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  active Boolean @default(true)
}

model Responsible {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  active Boolean @default(true)
}
