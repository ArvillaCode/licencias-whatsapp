# Local usa Postgres también (o puedes apuntar a la misma DB de la nube).
# Ejemplo Neon/Supabase: postgresql://usuario:password@host/db?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/apto_admin?schema=public"
PORT=4000
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# Solo en producción (Vercel): token de Vercel Blob para guardar evidencias.
# Si no está definido, las evidencias se guardan en disco local (dev).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
